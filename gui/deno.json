{
  "name": "@hyperpolymath/reposystem-gui",
  "version": "0.1.0",
  "tasks": {
    "dev": "tauri dev",
    "build": "tauri build",
    "dev:gossamer": "gossamer dev",
    "build:gossamer": "gossamer build",
    "dev:frontend": "rescript build -w & deno run --allow-read --allow-net npm:vite",
    "build:frontend": "rescript build && deno run --allow-read --allow-write --allow-env npm:vite build",
    "rescript": "^12.0.0",
    "rescript:watch": "rescript build -w",
    "rescript:clean": "rescript clean"
  },
  "imports": {
    "@tauri-apps/api": "npm:@tauri-apps/api@^2",
    "@gossamer/api": "npm:@gossamer/api@^1",
    "d3": "npm:d3@^7",
    "vite": "npm:vite@^5"
  }
}
