# Contractiles Mustfile - state contract
# See: https://github.com/hyperpolymath/mustfile

version: 1

metadata:
  name: contractiles-state-contract
  spec: v1.0.0
  description: "Invariant checks for policy, schema, gateway, and logs."

parameters:
  gateway_port: "8080"
  schema_version: "v1.0.0"

checks:
  - name: policy-config-valid
    description: "config/policy.yaml must be valid."
    run: just validate-policy

  - name: policy-nickel-compiles
    description: "policy/policy.ncl must compile."
    run: just compile-nickel

  - name: gateway-exposes-port
    description: "Gateway must expose the configured port."
    run: "bash -uc 'ss -lnt | rg \":${GATEWAY_PORT:-8080}\"'"

  - name: logs-are-json
    description: "Logs must be JSON."
    run: "bash -uc 'rg --files -g \"*.json\" logs | xargs -r jq -e .'"

  - name: schema-version-matches
    description: "Schema version must match the contract."
    run: "bash -uc 'rg -n \"${SCHEMA_VERSION:-v1.0.0}\" schema'"
