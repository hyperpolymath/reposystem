# RSR-compliant .gitignore

# OS & Editor
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# Build
/target/
/_build/
/build/
/dist/
/out/

# Dependencies
/node_modules/
/vendor/
/deps/
/.elixir_ls/

# Rust
# Cargo.lock  # Keep for binaries

# Zig
/ffi/zig/zig-cache/
/ffi/zig/zig-out/
/ffi/zig/.zig-cache/

# Idris2
/src/abi/build/
/src/abi/.idris2/

# Generated ABI headers
/generated/abi/*.h

# Gleam
/services/build/
/services/_gleam_artefacts/

# Elixir
/cover/
/doc/
*.ez
erl_crash.dump

# Julia
*.jl.cov
*.jl.mem
/Manifest.toml

# ReScript
/lib/bs/
/.bsb.lock
*.res.mjs

# Deno
/.deno/
/deno.lock

# Python (SaltStack only)
__pycache__/
*.py[cod]
.venv/

# Ada/SPARK
*.ali
/obj/
/bin/

# Haskell
/.stack-work/
/dist-newstyle/

# Chapel
*.chpl.tmp.*

# Secrets
.env
.env.*
*.pem
*.key
secrets/

# Test/Coverage
/coverage/
htmlcov/

# Logs
*.log
/logs/

# Fuzzing
/fuzz/corpus/
/fuzz/artifacts/
/fuzz/coverage/
*.profraw

# Temp
/tmp/
*.tmp
*.bak
target/
node_modules/
_build/
deps/
.elixir_ls/
.cache/
build/
dist/
