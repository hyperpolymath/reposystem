# total-upgrade Justfile
# Compliant with RSR/hyperpolymath standards

set shell := ["bash", "-uc"]
set dotenv-load := true
set positional-arguments := true

project := "total-upgrade"
version := "0.1.0"
tier := "infrastructure"

# DEFAULT & HELP
default:
    @just --list --unsorted

# BUILD & COMPILE
build:
    cargo build

build-release:
    cargo build --release

clean:
    rm -rf target

# TEST & QUALITY
test:
    cargo test

lint:
    cargo clippy -- -D warnings

fmt:
    cargo fmt

quality: fmt lint test

# RUN & EXECUTE
run *args:
    cargo run -- {{args}}

daemon:
    cargo run --release -- --daemon

# SYSTEM INTEGRATION
integ: build-release
    ./launcher/total-upgrade-launcher.sh --integ

disinteg:
    ./launcher/total-upgrade-launcher.sh --disinteg

status:
    ./launcher/total-upgrade-launcher.sh --status

# GUIX & CONTAINERS
guix-shell:
    guix shell -m manifest.scm

container-build:
    podman build -t {{project}}:latest .

container-run:
    podman run --rm -it {{project}}:latest

# DOCUMENTATION
docs:
    asciidoctor README.adoc
