# Build automation for recon-silly-ation (Deno + WASM + Podman)
# https://github.com/casey/just

# Default recipe
default:
    @just --list

# Install Deno (if not already installed)
install-deno:
    @if ! command -v deno &> /dev/null; then \
        echo "Installing Deno..."; \
        curl -fsSL https://deno.land/install.sh | sh; \
    else \
        echo "Deno already installed:"; \
        deno --version; \
    fi

# Install Rust (for WASM building)
install-rust:
    @if ! command -v cargo &> /dev/null; then \
        echo "Installing Rust..."; \
        curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y; \
    else \
        echo "Rust already installed:"; \
        rustc --version; \
    fi

# Install ReScript toolchain (dev-only shim via pnpm)
install-rescript:
    @if [ ! -d node_modules/.bin ]; then \
        echo "Installing ReScript toolchain via pnpm..."; \
        COREPACK_INTEGRITY_KEYS=0 pnpm install --ignore-scripts; \
    else \
        echo "ReScript toolchain already installed."; \
    fi

# Build ReScript sources (emits src/*.bs.js via in-source: true)
rescript-build: install-rescript
    ./node_modules/.bin/rescript build

# Clean ReScript build artifacts (in-source .bs.js files)
rescript-clean:
    ./node_modules/.bin/rescript clean

# Cache Deno dependencies — primary entry point is the compiled CLI
cache: rescript-build
    deno cache src/CLI.bs.js

# Build WASM modules from Rust
build-wasm: install-rust
    deno task build:wasm

# Build everything (ReScript + WASM + Deno cache)
build: rescript-build build-wasm cache
    @echo "✅ Build complete"

# Clean build artifacts
clean: rescript-clean
    rm -rf lib/
    rm -rf wasm-modules/target/
    rm -rf bin/
    rm -f src/wasm/hasher.wasm
    @echo "✅ Cleaned"

# Run the CLI (via compiled ReScript)
run *ARGS: rescript-build
    deno run --allow-all src/CLI.bs.js {{ARGS}}

# Scan a repository
scan REPO: rescript-build
    deno run --allow-all src/CLI.bs.js scan --repo reposystem

# Run in daemon mode
daemon REPO INTERVAL="300": rescript-build
    deno run --allow-all src/CLI.bs.js daemon --repo reposystem --interval {{INTERVAL}}

# Compile to AOT binary
compile: build
    deno task compile:aot

# Run tests (ReScript build first, then deno task)
test: rescript-build
    deno task test

# Type check (runs rescript build as the canonical check)
check: rescript-build
    @echo "✅ ReScript type-check passed via rescript build"

# Lint code
lint:
    deno lint src/ tests/

# Format code
fmt:
    deno fmt src/ tests/ scripts/

# Full development setup
dev-setup: install-deno install-rust build
    @echo "✅ Development environment ready!"

# Podman build
podman-build:
    podman build -t recon-silly-ation:latest -f Containerfile .

# Podman compose up
podman-up:
    podman-compose up

# Full CI check
ci: lint check test
    @echo "✅ CI checks passed!"

# Help
help:
    @echo "recon-silly-ation - Deno + WASM Edition"
    @echo ""
    @echo "  just build            - Build WASM + cache deps"
    @echo "  just scan REPO        - Scan repository"
    @echo "  just compile          - Compile AOT binary"
    @echo "  just test             - Run tests"
    @echo "  just podman-build     - Build container"
    @echo ""
    @echo "Full list: just --list"
