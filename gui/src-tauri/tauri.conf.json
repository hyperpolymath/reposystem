{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "reposystem-gui",
  "version": "0.1.0",
  "identifier": "com.hyperpolymath.reposystem",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "deno task dev:frontend",
    "beforeBuildCommand": "deno task build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Reposystem - Railway Yard",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
